# Local Docker development config.
#
# Copy to .env.dev, fill in real external-service keys if you need live agents,
# then run:
#   docker compose --env-file .env.dev -f docker-compose.yml -f docker-compose.dev.yml up -d --build
#
# This file avoids the public cloud tunnel/custom-domain path. It uses the
# bundled Docker Postgres by leaving NEON_DATABASE_URL empty.

CONTROL_PLANE_ENV_FILE=.env.dev
POSTGRES_PORT=55432

ZULIP_SITE=http://127.0.0.1:9999
PUBLIC_BASE_URL=http://127.0.0.1:8000
NEON_DATABASE_URL=

OPENAI_KEY=replace-me

OPENAI_IMAGES_ENABLED=false
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_DEFAULT_SIZE=1024x1024
OPENAI_IMAGE_DEFAULT_QUALITY=low
OPENAI_IMAGE_DEFAULT_FORMAT=png
OPENAI_IMAGE_TIMEOUT_S=120.0
OPENAI_IMAGE_MAX_BYTES=20000000

ZULIP_ADMIN_EMAIL=
ZULIP_ADMIN_API_KEY=

# Generate a local key with:
#   uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AGENT_FERNET_KEY=replace-me

JOB_WORKER_COUNT=2
CONTEXT_DEFAULT_N=20
TURN_TIMEOUT_SECONDS=300
SCHEDULER_ENABLED=false
PORT=8000

RUN_LIVE_AGENT_E2E=0
CONTROL_PLANE_URL=http://127.0.0.1:8000
ZULIP_BOT_ID=
ZULIP_BOT_EMAIL=
ZULIP_BOT_API_KEY=
ZULIP_OUTGOING_TOKEN=
E2E_AGENT_NAME=live-e2e-agent
E2E_ZULIP_MENTION_NAME=live-e2e-agent
E2E_ZULIP_CHANNEL=sandbox
E2E_TIMEOUT_SECONDS=90
E2E_CLEANUP_ZULIP_TOPIC=true
E2E_CLEANUP_CREATED_AGENT=true

BASTION_NAME=Bastion
BASTION_BOT_ID=
BASTION_BOT_EMAIL=
BASTION_API_KEY=
BASTION_OUTGOING_TOKEN=
BASTION_CHANNELS=sandbox

AGENT_MEMORY_ENABLED=false
# For app containers with `--profile memory`, use http://agent-memory:8000.
# From the host, the same service is published at http://127.0.0.1:${AGENT_MEMORY_PORT:-18000}.
AGENT_MEMORY_ENDPOINT=http://agent-memory:8000
AGENT_MEMORY_PORT=18000
AGENT_MEMORY_STORE_ID=
AGENT_MEMORY_API_KEY=
AGENT_MEMORY_TIMEOUT_S=10.0

TAVILY_MCP_ENABLED=false
TAVILY_MCP_URL=https://mcp.tavily.com/mcp/
TAVILY_API_KEY=
TAVILY_MCP_TIMEOUT_S=30.0

CONTEXT7_ENABLED=true
CONTEXT7_COMMAND='["npx", "-y", "@upstash/context7-mcp"]'
CONTEXT7_TIMEOUT_S=30.0

CODEX_WORKSPACE_ROOT=./var/codex-workspaces
CODEX_DEFAULT_SANDBOX_MODE=danger-full-access

exec_mcp_enabled=false
exec_mcp_url=
exec_mcp_token=
exec_require_confirm=true
exec_channels=
exec_users=
