# Zulip org base URL. Use your own Zulip org for live webhook/e2e runs.
ZULIP_SITE=https://example.zulipchat.com

# Compose uses this to decide which app env file to load into the container.
# For prod/cloud local runs leave unset (defaults to .env). For local dev, set
# CONTROL_PLANE_ENV_FILE=.env.dev and run docker compose with --env-file .env.dev.
CONTROL_PLANE_ENV_FILE=

# Public HTTPS base URL Zulip's outgoing webhook reaches (your cloudflared tunnel
# host). Used as the payload_url for auto-provisioned bots. Falls back to
# ZULIP_SITE if unset (fine for tests, wrong for a live tunnel).
PUBLIC_BASE_URL=https://<your-tunnel-host>

# Postgres connection URL, async driver. The name is historical — ANY Postgres
# works, not just Neon. Self-hosting? Point this at your own/Dockerized Postgres,
# e.g. the docker-compose service below:
#   NEON_DATABASE_URL=postgresql+asyncpg://control_plane:control_plane@db:5432/control_plane
# The engine auto-forces the asyncpg driver and only enables SSL when the URL
# asks for it (sslmode=require/verify-*); a local DB with no sslmode runs plaintext.
# Neon specifically requires SSL and closes idle connections — both handled in db/engine.py.
NEON_DATABASE_URL=postgresql+asyncpg://user:password@host/dbname

# OpenAI API key for all OpenAI-backed runtime calls. In production this comes
# from the 1Password-backed .env on the box; do not commit a real key.
OPENAI_KEY=replace-me

# --- OpenAI image generation tool ---
# OFF by default. When enabled, agents with the generate_image tool can spend
# OPENAI_KEY quota to generate an image and post it back to Zulip.
OPENAI_IMAGES_ENABLED=false
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_DEFAULT_SIZE=1024x1024
OPENAI_IMAGE_DEFAULT_QUALITY=low
OPENAI_IMAGE_DEFAULT_FORMAT=png
OPENAI_IMAGE_TIMEOUT_S=120.0
OPENAI_IMAGE_MAX_BYTES=20000000

# Admin account used to auto-provision bots via Zulip's /json/bots.
ZULIP_ADMIN_EMAIL=admin@example.zulipchat.com
ZULIP_ADMIN_API_KEY=replace-me

# Fernet key for encrypting bot credentials at rest. Generate with:
#   uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AGENT_FERNET_KEY=replace-me

# Number of in-process worker coroutines, and default topic-context window.
JOB_WORKER_COUNT=2
CONTEXT_DEFAULT_N=20
# Wall-clock seconds before a single agent turn is cancelled and failed (frees the
# worker slot; the turn is dropped, not replayed). Default 300.
TURN_TIMEOUT_SECONDS=300
SCHEDULER_ENABLED=true

PORT=8000

# --- Docker self-host (see docker-compose.yml) ---
# Leave NEON_DATABASE_URL unset to use the bundled Postgres container, or set it
# (above) to an external Postgres/Neon. Only needed for the optional `tunnel`
# profile: a Cloudflare tunnel token (dashboard -> Zero Trust -> Tunnels). Route
# the tunnel's public hostname to http://app:8000.
POSTGRES_PORT=55432
CLOUDFLARE_TUNNEL_TOKEN=

# Optional live e2e test values. These are only used when explicitly running:
#   RUN_LIVE_AGENT_E2E=1 uv run pytest tests/e2e/test_live_zulip_agent_e2e.py -v
RUN_LIVE_AGENT_E2E=0
CONTROL_PLANE_URL=http://127.0.0.1:8000
ZULIP_BOT_ID=
ZULIP_BOT_EMAIL=
ZULIP_BOT_API_KEY=
ZULIP_OUTGOING_TOKEN=
E2E_AGENT_NAME=live-e2e-agent
E2E_ZULIP_MENTION_NAME=live-e2e-agent
E2E_ZULIP_CHANNEL=sandbox
E2E_TIMEOUT_SECONDS=90
E2E_CLEANUP_ZULIP_TOPIC=true
E2E_CLEANUP_CREATED_AGENT=true

# --- Bastion management agent (optional; unset = not seeded) ---
BASTION_NAME=Bastion
BASTION_BOT_ID=
BASTION_BOT_EMAIL=
BASTION_API_KEY=
BASTION_OUTGOING_TOKEN=
# BASTION_PERSONA=        # optional override of the shipped persona
# BASTION_MODEL_ID=       # optional; defaults to gpt-4o

# --- Agent memory ---
# OFF by default. For Redis Cloud Agent Memory, set endpoint + store id + API key.
# For the local Docker memory profile, use AGENT_MEMORY_ENDPOINT=http://agent-memory:8000
# and leave store id / API key empty.
AGENT_MEMORY_ENABLED=false
AGENT_MEMORY_ENDPOINT=https://gcp-us-east4.memory.redis.io
AGENT_MEMORY_STORE_ID=
AGENT_MEMORY_API_KEY=
AGENT_MEMORY_TIMEOUT_S=10.0

# --- Web access via Tavily's hosted remote MCP (https://mcp.tavily.com/mcp/) ---
# NOTE: like agent memory, this points at a specific managed MCP (Tavily's hosted
# server). It is OFF by default and optional — self-host without it, or point
# TAVILY_MCP_URL at your own MCP server exposing the same tool interface.
# Set TAVILY_MCP_ENABLED=true and supply a key from https://www.tavily.com/
# to register the Tavily search/extract/crawl/map/research tools. When off,
# the tools are not registered and behavior is identical.
TAVILY_MCP_ENABLED=false
TAVILY_MCP_URL=https://mcp.tavily.com/mcp/
TAVILY_API_KEY=
TAVILY_MCP_TIMEOUT_S=30.0

# --- Codex runtime (runtime_kind="codex") ---
# Root dir for per-topic agent workspaces (each git-init'd once). Reuses OPENAI_KEY
# as CODEX_API_KEY; requires the `codex` binary on the box (npm i -g @openai/codex).
CODEX_WORKSPACE_ROOT=./var/codex-workspaces
# Default codex --sandbox when an agent doesn't set runtime_config.codex.sandbox_mode.
# Local dev: workspace-write (codex sandboxes itself). The CONTAINERIZED box must set
# danger-full-access because codex's own Landlock/seccomp sandbox can't start inside
# Docker — the container is the isolation boundary. {read-only,workspace-write,danger-full-access}
CODEX_DEFAULT_SANDBOX_MODE=workspace-write
