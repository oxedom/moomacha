{
  "name": "whatsapp-sidecar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Minimal read-only WhatsApp (Baileys) sidecar: streams all incoming messages from logged-in accounts to subscribers (in-process bus + loopback SSE).",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "whatsapp-sidecar": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "serve": "tsx src/index.ts",
    "pair": "tsx src/pair.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.17.16",
    "pino": "^9.5.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
